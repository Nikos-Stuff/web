---
const {
  isAnimated = false,
  theme = "default",
  margin_bottom = "10",
  class: extraClass = "",
} = Astro.props;

const validMargins: Record<string, string> = {
  "0": "mb-0",
  "10": "mb-10",
  "24": "mb-24",
  "50": "mb-50",
  "100": "mb-100",
  "250": "mb-[250px]",
};

const marginBottom = validMargins[String(margin_bottom)] ?? "mb-10";

// Universal themes
const themeVariants: Record<string, string> = {
  default_h: `
    mx-auto max-w-screen-sm p-5 ${marginBottom} space-y-24 backdrop-blur-2xl 
    backdrop-brightness-75 sm:rounded-2xl animate sm:border border-t border-b
    border-orange-300/40 ${extraClass}
    shadow-[0_0_25px_rgba(255,115,0,0.4)]
  `,

  default: `
    mx-auto max-w-screen-md p-6 ${marginBottom} space-y-6 
    backdrop-blur-xl bg-zinc-900/10
    sm:rounded-xl animate sm:border border-t border-b
    border-white/10 ${extraClass}
  `,

  default_big: `
    mx-auto max-w-screen-md p-5 ${marginBottom} space-y-24 backdrop-blur-2xl 
    backdrop-brightness-50 sm:rounded-2xl animate sm:border border-t border-b
    border-white/25 ${extraClass}
  `,

  default_big_no_p: `
    mx-auto max-w-screen-md ${marginBottom} space-y-24 backdrop-blur-2xl 
    backdrop-brightness-50 sm:rounded-2xl animate sm:border border-t border-b
    border-white/25 ${extraClass}
  `,

  alert: `
    mx-auto max-w-screen-sm p-5 ${marginBottom} space-y-24 backdrop-blur-2xl bg-yellow-400/5
    backdrop-brightness-50 sm:rounded-2xl animate sm:border border-t border-b
    border-white/25 ${extraClass}
  `,

  minecraft: `
    mx-auto max-w-screen-sm p-5 ${marginBottom} space-y-24 backdrop-blur-2xl 
    backdrop-brightness-50 sm:rounded-none animate sm:border border-t border-b
    border-white/25 ${extraClass}
    bg-[#00170d]/50
    bg-[radial-gradient(#ffffff33_1px,transparent_1px)]
  `,

  lite: `
    mx-auto max-w-screen-md p-6 ${marginBottom} space-y-6 
    bg-zinc-900/10
    sm:rounded-xl animate sm:border border-t border-b
    border-white/10 ${extraClass}
  `,

  simple_full_width_blurred_bg: `
    w-full p-5 ${marginBottom} space-y-24 backdrop-blur-2xl 
    backdrop-brightness-75 animate border-t border-b border-white/20
    ${extraClass}
  `,

  simple_full_width: `
    w-full p-5 ${marginBottom} space-y-24 bg-black animate border-t border-b border-white/20
    ${extraClass}
  `,
};

const divClass = themeVariants[theme] ?? themeVariants.default;
---

<div
  class={divClass}
  {...isAnimated
    ? { "data-cursor-hover": true, "data-cursor-parallax": true }
    : {}}
>
  <slot />
</div>
