---
import FancyDiv from "@components/FancyDiv.astro";
---

<div>
  <FancyDiv theme="simple_full_width_blurred_bg" margin_bottom="50">
    <section class="animate max-w-3xl mx-auto py-12 space-y-12">
      <div
        class="relative animate w-full border border-white/10 rounded-xl h-44 flex flex-col justify-center items-center overflow-hidden bg-neutral-900/20"
      >
        <div
          class="absolute -top-10 left-1/2 -translate-x-1/2 w-40 h-40 bg-white/5 rounded-full blur-3xl pointer-events-none"
        >
        </div>

        <p
          id="animate_num"
          class="relative text-center text-8xl font-extrabold text-white tracking-tighter z-10 w-full leading-none"
          data-animate-num="40"
        >
          40
        </p>
        <p
          class="relative text-center text-sm font-medium uppercase tracking-wider text-neutral-400 mt-2 z-10"
        >
          zadowolonych klientów
        </p>
      </div>

      <hr class="border-white/10 animate" />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="animate space-y-2">
          <h3 class="font-bold text-xl text-white tracking-tight">
            Sprawdzone Rozwiązania
          </h3>
          <p class="text-xs text-neutral-400 leading-relaxed">
            <span class="font-semibold text-white"
              >Ponad 5 lat stałej praktyki</span
            > oznacza, że nie eksperymentuję. Dostarczam najlepsze techniki montażu
            wideo oraz optymalizacji stron.
          </p>
        </div>

        <div class="animate space-y-2">
          <h3 class="font-bold text-xl text-white tracking-tight">
            Gwarancja Satysfakcji
          </h3>
          <p class="text-xs text-neutral-400 leading-relaxed">
            <span class="font-semibold text-white">Nie ma limitu poprawek.</span
            > Pracuję aż do Twojej 100% satysfakcji, ponieważ wyceniamy <span
              class="font-semibold text-white">rezultat</span
            >, a nie liczbę godzin pracy.
          </p>
        </div>

        <div class="animate space-y-2">
          <h3 class="font-bold text-xl text-white tracking-tight">
            Wsparcie i Bezpieczeństwo
          </h3>
          <p class="text-xs text-neutral-400 leading-relaxed">
            <span class="font-semibold text-white">Nie znikam po wysyłce!</span> Oferuję
            konsultacje po wdrożeniu strony, pomoc w obsłudze systemów (CMS) i wsparcie
            techniczne specjalnie dla Ciebie.
          </p>
        </div>
      </div>

      <hr class="border-white/10 animate" />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div
          class="relative flex-1 animate border border-white/10 rounded-xl p-6 bg-neutral-900/10 flex flex-col justify-center items-center overflow-hidden"
        >
          <p
            class="relative text-center text-4xl md:text-5xl font-extrabold text-white tracking-tight z-10 w-full"
            data-animate-num="2"
            data-suffix="h"
          >
            2h
          </p>
          <p
            class="relative text-center text-xs text-neutral-400 font-medium tracking-wide mt-1 text-balance z-10"
          >
            Ekspresowy czas odpowiedzi
          </p>
        </div>

        <div
          class="relative flex-1 animate border border-white/10 rounded-xl p-6 bg-neutral-900/10 flex flex-col justify-center items-center overflow-hidden"
        >
          <p
            class="relative text-center text-4xl md:text-5xl font-extrabold text-white tracking-tight z-10 w-full"
            data-animate-num="0"
            data-start="99"
            data-suffix="%"
          >
            0%
          </p>
          <p
            class="relative text-center text-xs text-neutral-400 font-medium tracking-wide mt-1 text-balance z-10"
          >
            Współczynnik reklamacji
          </p>
        </div>

        <div
          class="relative flex-1 animate border border-white/10 rounded-xl p-6 bg-neutral-900/10 flex flex-col justify-center items-center overflow-hidden"
        >
          <p
            class="relative text-center text-4xl md:text-5xl font-extrabold text-white tracking-tight z-10 w-full"
            data-animate-num="6"
            data-suffix="mo"
          >
            6mo
          </p>
          <p
            class="relative text-center text-xs text-neutral-400 font-medium tracking-wide mt-1 text-balance z-10"
          >
            Gwarancja i wsparcie
          </p>
        </div>
      </div>
    </section>
  </FancyDiv>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const animateNumbers = () => {
    const elements =
      document.querySelectorAll<HTMLElement>("[data-animate-num]");

    const parseNumber = (value: string | undefined, fallback = 0) => {
      const parsed = Number(value);
      return isNaN(parsed) ? fallback : parsed;
    };

    elements.forEach((el) => {
      const dataset = el.dataset;
      const targetValue = parseNumber(dataset.animateNum);
      const startValue = parseNumber(dataset.start);
      const suffix = dataset.suffix || "";
      const obj = { value: startValue };

      // Set initial value
      el.textContent = Math.floor(startValue).toString() + suffix;

      gsap.to(obj, {
        value: targetValue,
        duration: 2,
        ease: "power1.inOut",
        onUpdate: () => {
          el.textContent = Math.floor(obj.value).toString() + suffix;
        },
        paused: true,
      });

      ScrollTrigger.create({
        trigger: el,
        start: "top 80%",
        toggleActions: "play reverse play reverse",
        onEnter: () =>
          gsap.to(obj, {
            value: targetValue,
            duration: 2,
            ease: "power1.inOut",
            onUpdate: () => {
              el.textContent = Math.floor(obj.value) + suffix;
            },
          }),
        onLeaveBack: () =>
          gsap.to(obj, {
            value: startValue,
            duration: 2,
            ease: "power1.inOut",
            onUpdate: () => {
              el.textContent = Math.floor(obj.value) + suffix;
            },
          }),
      });
    });
  };

  document.addEventListener("DOMContentLoaded", animateNumbers);
</script>
