---
import { SITE, LINKS } from "@consts";
import { cn } from "@lib/utils";
const { pathname } = Astro.url;
const subpath = pathname.match(/[^/]+/g);
import Container from "@components/Container.astro";
import HeaderIcon from "@components/web_icon.astro";
---

<header
  id="header"
  class="fixed top-0 w-full h-16 z-40 backdrop-blur-md bg-neutral-950/50 border-b border-white/5 transition-colors duration-500"
>
  <Container size="lg">
    <div class="relative h-full w-full flex items-center justify-between">
      <div class="flex items-center">
        <a
          href="/"
          class="flex gap-2.5 items-center font-bold text-white transition-opacity hover:opacity-80"
        >
          <HeaderIcon />
          <span class="tracking-tight">{SITE.TITLE}</span>
        </a>
      </div>

      <nav
        class="hidden lg:flex items-center gap-1 bg-white/5 p-1 rounded-full"
      >
        {
          LINKS.map((LINK) => (
            <a
              href={LINK.HREF}
              class={cn(
                "h-8 px-4 text-xs font-medium rounded-full whitespace-nowrap flex items-center transition-all duration-300",
                pathname === LINK.HREF || "/" + subpath?.[0] === LINK.HREF
                  ? "bg-neutral-800 text-white shadow-sm"
                  : "text-neutral-400 hover:text-white",
              )}
            >
              {LINK.TEXT}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-2">
        <a
          href="/search"
          aria-label="Search"
          class={cn(
            "hidden lg:flex size-9 rounded-full items-center justify-center border transition-all duration-300",
            "border-white/10 hover:bg-white/10",
            pathname === "/search" ? "bg-white/10" : "",
          )}
        >
          <i
            class="ph ph-magnifying-glass text-lg flex items-center justify-center"
          ></i>
        </a>

        <button
          id="header-drawer-button"
          aria-label="Toggle menu"
          class="flex lg:hidden size-9 rounded-full items-center justify-center border border-white/10 hover:bg-white/10 transition-all"
        >
          <div
            id="drawer-open"
            class="flex items-center justify-center text-lg"
          >
            <i class="ph ph-dots-three-outline"></i>
          </div>
          <div
            id="drawer-close"
            class="hidden items-center justify-center text-lg"
          >
            <i class="ph ph-x"></i>
          </div>
        </button>
      </div>
    </div>
  </Container>
</header>

<style>
  #header-drawer-button.open > #drawer-open {
    display: none;
  }
  #header-drawer-button.open > #drawer-close {
    display: flex;
  }
</style>

<script>
  function toggleDrawer() {
    const drawer = document.getElementById("drawer");
    const drawerButton = document.getElementById("header-drawer-button");
    drawer?.classList.toggle("open");
    drawerButton?.classList.toggle("open");
  }

  function initializeDrawerButton() {
    const drawerButton = document.getElementById("header-drawer-button");
    drawerButton?.addEventListener("click", toggleDrawer);
  }

  document.addEventListener("astro:after-swap", initializeDrawerButton);
  initializeDrawerButton();
</script>
