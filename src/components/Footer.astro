---
import { SITE, SOCIALS } from "@consts";
import Container from "@components/Container.astro";
import HeaderIcon from "@components/web_icon.astro";
import PageVersion from "@components/GitVer.astro";

const currentYear = new Date().getFullYear();
---

<script is:inline async src="/js/system_detection.js"></script>

<footer
  class="mt-20 border-t border-white/5 bg-neutral-950/50 backdrop-blur-md"
>
  <Container size="md">
    <div class="py-12 space-y-12">
      <div class="flex flex-col md:flex-row justify-between items-center gap-8">
        <a
          href="/"
          class="flex gap-2.5 items-center font-bold text-white transition-opacity hover:opacity-80"
        >
          <HeaderIcon />
          <span>{SITE.TITLE}</span>
        </a>

        <div class="flex gap-1 items-center">
          {
            SOCIALS.map((SOCIAL) => (
              <a
                href={SOCIAL.HREF}
                target="_blank"
                aria-label={`${SITE.TITLE} on ${SOCIAL.NAME}`}
                class="size-10 rounded-full flex items-center justify-center hover:bg-white/10 transition-colors"
              >
                <i class={`${SOCIAL.ICON} text-lg`} />
              </a>
            ))
          }
        </div>
      </div>

      <div
        class="flex flex-col sm:flex-row justify-between items-center gap-6 pt-8 border-t border-white/5"
      >
        <div
          class="text-xs text-neutral-500 space-y-1 text-center sm:text-left"
        >
          <a
            href="https://dc.nikostuff.com"
            class="hover:text-white transition-colors"
          >
            Created & Built with ❤️ by Niko / M.F.
          </a>
          <div class="font-mono opacity-70">
            &copy; {currentYear} | <PageVersion />
          </div>
        </div>

        <button
          id="back-to-top"
          aria-label="Back to top"
          class="group flex gap-2 items-center px-4 py-2 text-xs font-semibold uppercase tracking-wider border border-white/10 rounded-full hover:bg-white/10 transition-all duration-300"
        >
          <span>Do Góry</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="stroke-current rotate-90"
          >
            <line
              x1="19"
              y1="12"
              x2="5"
              y2="12"
              class="scale-x-0 group-hover:scale-x-100 translate-x-3 group-hover:translate-x-0 transition-all duration-300"
            ></line>
            <polyline
              points="12 19 5 12 12 5"
              class="translate-x-1 group-hover:translate-x-0 transition-all duration-300"
            ></polyline>
          </svg>
        </button>
      </div>
    </div>
  </Container>
</footer>

<script is:inline>
  function goBackToTop(event) {
    event.preventDefault();
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  function initializeBackToTop() {
    const backToTop = document.getElementById("back-to-top");
    backToTop?.addEventListener("click", goBackToTop);
  }

  document.addEventListener("astro:after-swap", initializeBackToTop);
  initializeBackToTop();
</script>
