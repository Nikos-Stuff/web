<script>
  import { gsap } from "gsap";

  const phrases = [
    "W trakcie przebudowy...",
    "Under construction...",
    "In Bearbeitung...",
    "En construction...",
    "Estamos en obras...",
  ];

  let currentIdx = 0;
  const headlineEl = document.getElementById("dynamic-headline");

  function buildWordSpans(text: string) {
    if (!headlineEl) return;
    headlineEl.innerHTML = "";

    text.split(" ").forEach((word) => {
      const span = document.createElement("span");
      span.innerText = word;
      
      span.classList.add("inline-block", "opacity-0", "select-none");
      
      headlineEl.appendChild(span);
    });
  }

  function cycleLanguages() {
    if (!headlineEl) return;

    buildWordSpans(phrases[currentIdx]);

    const words = headlineEl.querySelectorAll("span");
    const timeline = gsap.timeline({
      onComplete: () => {
        currentIdx = (currentIdx + 1) % phrases.length;
        gsap.delayedCall(1.2, cycleLanguages);
      },
    });
    timeline
      .fromTo(
        words,
        { y: 25, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.5, stagger: 0.12, ease: "power2.out" },
      )
      .to(words, {
        y: -25,
        opacity: 0,
        duration: 0.4,
        stagger: 0.08,
        ease: "power2.in",
        delay: 2.5,
      });
  }

  cycleLanguages();
</script>
