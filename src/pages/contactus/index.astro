---
// export const prerender = false;
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@consts";
import TwinklingStars from "@components/TwinklingStars.astro";
import MeteorShower from "@components/MeteorShower.astro";

import FancyDiv from "@components/FancyDiv.astro";
import DynamicTitle from "@components/TitleHeader.astro";
import BackgroundFX from "@components/page_effects/BackgroundFX.astro";

import POD from "@components/POD.astro";
---

<PageLayout title="Home" description={SITE.DESCRIPTION}>
  <!-- <script is:inline data-astro-rerun async src="/js/scroll_animation.js"
  ></script> -->

  <POD />
  <!-- Dark Theme: Stars -->
  <div class="absolute inset-0 block">
    <div id="stars1" class="fixed inset-0"></div>
    <div id="stars2" class="fixed inset-0"></div>
    <div id="stars3" class="fixed inset-0"></div>
  </div>

  <!-- Dark Theme: Twinkling Stars / Metors -->
  <div id="galaxy" class="fixed inset-0">
    <div class="block">
      <TwinklingStars />
      <MeteorShower />
    </div>
  </div>

  <!-- <script is:inline defer src="/js/bg.js"></script> -->
  <BackgroundFX />
  <!-- HERO -->
  <section
    id="hero_fade"
    class="snap-center grid w-full h-svh place-items-center relative text-center overflow-hidden transition-all"
  >
    <DynamicTitle
      text="Kontakt"
      sub="Złóż zamówienie, zapytaj o cokolwiek"
      buttons={false}
      typewriter={false}
    />
  </section>

  <div class="relative">
    <FancyDiv isAnimated={true} theme="default_big" margin_bottom="10">
      <div class="transition-all">
        <p
          class="text-xl md:text-2xl lg:text-3xl font-bold uppercase text-white animate"
        >
          Formularz kontaktowy
        </p>
        <p class="font-bold text-sm mb-2 animate">
          Ekspresowa odpowiedź gwarantowana!
        </p>

        <div class="space-y-4 animate" id="calculator">
          <!-- E-mail -->
          <div class="relative mb-5" id="ip_input_box">
            <label for="email" class="mt-5 text-sm font-medium mb-1 animate"
              >E-mail / Telefon:</label
            >
            <input
              id="email"
              type="email"
              placeholder="Twój e-mail lub nr telefonu"
              class="w-full p-4 mb-0 border rounded-lg
                    bg-transparent
                  border-white/20
                  hover:bg-white/10
                    focus:outline-none
                  focus:border-white/40
                    focus:ring-2 focus:focus:ring-white/20
                    focus:ring-offset-0
                    transition-all duration-300 ease-out"
            />
          </div>

          <!-- Category -->
          <div class="relative mb-5" id="category_input_box">
            <label for="category" class="mt-5 text-sm font-medium mb-1 animate"
              >Temat:</label
            >
            <input
              id="category"
              type="text"
              placeholder="Temat wiadomości"
              class="w-full p-4 mb-0 border rounded-lg
                        bg-transparent
                    border-white/20
                    hover:bg-white/10
                        focus:outline-none
                    focus:border-white/40
                        focus:ring-2focus:ring-white/20
                        focus:ring-offset-0
                        transition-all duration-300 ease-out"
            />
          </div>

          <!-- Message -->
          <div class="relative mb-5" id="message_input_box">
            <label for="message" class="mt-5 text-sm font-medium mb-1 animate"
              >Wiadomość:</label
            >
            <textarea
              id="message"
              placeholder="Twoja wiadomość"
              class="w-full p-4 mb-0 border rounded-lg
                            bg-transparent
                        border-white/20
                        hover:bg-white/10
                            focus:outline-none
                        focus:border-white/40
                            focus:ring-2 focus:ring-white/20
                            focus:ring-offset-0
                            transition-all duration-300 ease-out resize-none h-32"
            ></textarea>
          </div>

          <div class="animate">
            <button
              id="submit_button"
              class="group w-full p-4 gap-3 flex items-center border rounded-lg hover:bg-white/10 border-white/20 transition-all duration-300 ease-in-out"
            >
              <span
                class="w-full z-10 relative group-hover:text-white text-center transition-color duration-300"
              >
                Wyślij wiadomość
              </span>
            </button>
          </div>
        </div>
      </div>
    </FancyDiv>
  </div>
</PageLayout>

<script>
  const submitButton = document.getElementById(
    "submit_button",
  ) as HTMLButtonElement | null;
  const emailInput = document.getElementById(
    "email",
  ) as HTMLInputElement | null;
  const categoryInput = document.getElementById(
    "category",
  ) as HTMLInputElement | null;
  const messageInput = document.getElementById(
    "message",
  ) as HTMLTextAreaElement | null;

  const send_endpoint = "https://api.nikostuff.com/ContactFormAnalyzer";

  if (submitButton) {
    submitButton.addEventListener("click", async () => {
      if (!emailInput || !categoryInput || !messageInput) {
        alert("Błąd: Nie można znaleźć elementów formularza.");
        return;
      }

      const email = emailInput.value.trim();
      const category = categoryInput.value.trim();
      const message = messageInput.value.trim();

      if (!email || !category || !message) {
        alert("Proszę wypełnić wszystkie pola.");
        return;
      }

      try {
        const response = await fetch(send_endpoint, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ email, category, message }),
        });

        if (response.ok) {
          alert("Wiadomość została wysłana!");
          emailInput.value = "";
          categoryInput.value = "";
          messageInput.value = "";
        } else {
          alert("Wystąpił błąd podczas wysyłania wiadomości.");
        }
      } catch (error) {
        console.error("Błąd:", error);
        alert("Wystąpił błąd podczas wysyłania wiadomości.");
      }
    });
  }
</script>
