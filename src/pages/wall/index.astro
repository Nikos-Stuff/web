<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mój guest book</title>
    <link rel="stylesheet" href="https://unpkg.com/98.css" />
    <link rel="preconnect" href="https://challenges.cloudflare.com" />
    <style>
      .cf-turnstile {
        position: fixed;
        bottom: 20px;
        left: 20px;
        z-index: 9999 !important;

        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);

        mix-blend-mode: screen;

        opacity: 0.85;

        transform: scale(0.85);
        transform-origin: bottom left;
        pointer-events: auto;
      }
      /* Hide scrollbars globally */
      html,
      body {
        scrollbar-width: none;
        -ms-overflow-style: none;
        background: teal;
        font-family: "Microsoft Sans Serif", sans-serif;
        padding: 20px;
        overflow-x: hidden;
        cursor: url("/cursors/arrow.cur"), auto;
      }
      html::-webkit-scrollbar,
      body::-webkit-scrollbar {
        display: none;
      }

      .window {
        width: 300px;
        position: absolute;
        z-index: 1;
      }

      /* Mobile Stacking */
      @media (max-width: 600px) {
        .window {
          position: relative !important;
          top: 0 !important;
          left: 0 !important;
          width: 100% !important;
          margin-bottom: 20px;
        }
      }

      .chat-log {
        height: 150px;
        overflow-y: scroll;
        margin-top: 25px;
      }
      .marquee-container {
        width: 100%;
        overflow: hidden;
        border: 2px inset #ccc;
        margin-bottom: 10px;
      }

      /* Cursors */
      .title-bar {
        user-select: none;
        -webkit-user-select: none;
        cursor: url("/cursors/arrow.cur"), auto;
      }
      button,
      .title-bar-controls button {
        cursor: url("/cursors/Cursor_15.cur"), pointer !important;
      }
      input[type="text"],
      textarea {
        cursor: url("/cursors/Cursor_14.cur"), text;
      }
      label,
      legend {
        cursor: url("/cursors/help_win95.cur"), help;
      }

      /* Iframe styling to fit window */
      #ytPlayer {
        display: block;
        width: 100%;
        border: none;
      }

      #message {
        /* This prevents the user from resizing it at all */
        resize: none;
      }
    </style>

    <script
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer></script>
  </head>
  <body>
    <div
      id="first_interaction_grabber"
      style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
            background: rgba(0, 0, 0, 0.5); z-index: 99999; 
            display: flex; align-items: center; justify-content: center;"
    >
      <div
        class="window"
        data-not-moveable="true"
        style="position: relative; width: 300px;"
      >
        <div class="title-bar">
          <div class="title-bar-text">Witaj</div>
        </div>
        <div class="window-body" style="text-align: center;">
          <p>Witaj w moim Guest Book-u!</p>
          <p>Kliknij OK aby rozpoczac!</p>
          <section class="field-row" style="justify-content: center;">
            <button id="start_button" style="width: 80px;">OK</button>
          </section>
        </div>
      </div>
    </div>

    <div class="window" style="top: 50px; left: 50px;">
      <div class="title-bar">
        <div class="title-bar-text">Guest book</div>
        <div class="title-bar-controls">
          <button aria-label="Close" class="close" data-redirect="true"
          ></button>
        </div>
      </div>
      <div class="window-body">
        <div class="marquee-container">
          <marquee scrollamount="3">Witaj! Zostaw cos po sobie!</marquee>
        </div>
        <fieldset>
          <legend>Wpisz sie na sciane:</legend>
          <div class="field-row-stacked">
            <label for="nickname">Twoja ksywka:</label>
            <input id="nickname" type="text" autocomplete="off" />
          </div>
          <div class="field-row-stacked">
            <label for="message">Wiadomosc:</label>
            <textarea id="message" rows="3"></textarea>
          </div>
          <fieldset style="margin-top: 30px;">
            <button id="sendBtn">Wyslij wpis</button>
          </fieldset>
        </fieldset>
        <ul class="tree-view chat-log">
          <li><strong>System - </strong>Oczekiwanie...</li>
        </ul>
      </div>
      <audio id="intro_sound" src="/win98.ogv"></audio>
      <audio id="notify" src="/you_got_mail.ogg"></audio>
    </div>

    <div
      class="window"
      id="radioWindow"
      style="top: 120px; left: 400px; width: 360px;"
    >
      <div class="title-bar">
        <div class="title-bar-text">Lofi Radio</div>
        <div class="title-bar-controls">
          <button aria-label="Close" class="close"></button>
        </div>
      </div>
      <div class="window-body" style="padding: 0; background: black;">
        <iframe
          id="ytPlayer"
          height="200"
          src="https://www.youtube.com/embed/jfKfPfyJRdk?enablejsapi=1&controls=0&modestbranding=1&rel=0"
          allow="autoplay"
          style="pointer-events: none;"
        >
        </iframe>
      </div>
    </div>

    <script>
      // --- AUDIO SETUP ---
      const introAudio = document.getElementById(
        "intro_sound",
      ) as HTMLAudioElement | null;

      if (introAudio) {
        introAudio.volume = 0.2;
      }

      let shouldStartPlayback = false;

      // --- START BUTTON ---
      const startButton = document.getElementById("start_button");
      const overlay = document.getElementById("first_interaction_grabber");

      // --- YOUTUBE API LOAD ---
      const tag = document.createElement("script");
      tag.src = "https://www.youtube.com/iframe_api";
      document.head.appendChild(tag);

      // --- TYPES ---
      declare global {
        interface Window {
          onYouTubeIframeAPIReady: () => void;
          YT: any;
        }
      }

      let player: any = null;
      let ytReady = false;

      // --- INIT PLAYER ---
      window.onYouTubeIframeAPIReady = () => {
        player = new window.YT.Player("ytPlayer", {
          events: {
            onReady: (event: any) => {
              ytReady = true;
              event.target.setVolume(15);

              if (shouldStartPlayback) {
                event.target.playVideo();
              }
            },
          },
        });
      };

      // --- START EXPERIENCE ON CLICK ---
      startButton?.addEventListener("click", () => {
        overlay?.remove();

        // 🔊 audio
        if (introAudio) {
          introAudio.currentTime = 0;
          introAudio.play().catch((e) => {
            console.error("Intro audio failed:", e);
          });
        }

        shouldStartPlayback = true;

        if (player && ytReady) {
          player.playVideo();
        }
      });

      // --- DRAGGING & WINDOW LOGIC ---
      const windows = document.querySelectorAll<HTMLElement>(".window");
      let activeWindow: HTMLElement | null = null;
      let offsetX = 0,
        offsetY = 0;

      const CURSOR_MOVE = "url('/cursors/Cursor_10.cur'), move";
      const CURSOR_DEFAULT = "url('/cursors/arrow.cur'), auto";

      let zCounter = 100;

      function setActiveWindow(win: HTMLElement) {
        windows.forEach((w) => {
          const titleBar = w.querySelector<HTMLElement>(".title-bar");
          if (titleBar) titleBar.classList.add("inactive");
        });

        const titleBar = win.querySelector<HTMLElement>(".title-bar");
        if (titleBar) titleBar.classList.remove("inactive");

        zCounter += 1;
        win.style.zIndex = `${zCounter}`;
      }

      windows.forEach((win) => {
        if (win.dataset.notMoveable === "true") return;

        const titleBar = win.querySelector<HTMLElement>(".title-bar");
        if (!titleBar) return;

        titleBar.addEventListener("mousedown", (e) => {
          if (
            window.innerWidth <= 600 ||
            (e.target as HTMLElement).tagName === "BUTTON"
          )
            return;

          activeWindow = win;
          const rect = win.getBoundingClientRect();
          offsetX = e.clientX - rect.left;
          offsetY = e.clientY - rect.top;

          document.body.style.cursor = CURSOR_MOVE;
          win.style.cursor = CURSOR_MOVE;
          titleBar.style.cursor = CURSOR_MOVE;

          setActiveWindow(win);
        });

        titleBar.addEventListener("click", () => {
          setActiveWindow(win);
        });
      });

      document.addEventListener("mousemove", (e) => {
        if (!activeWindow) return;
        activeWindow.style.left = `${e.clientX - offsetX}px`;
        activeWindow.style.top = `${e.clientY - offsetY}px`;
      });

      document.addEventListener("mouseup", () => {
        if (!activeWindow) return;

        document.body.style.cursor = "";
        const titleBar = activeWindow.querySelector<HTMLElement>(".title-bar");
        if (titleBar) titleBar.style.cursor = CURSOR_DEFAULT;

        activeWindow.style.cursor = CURSOR_DEFAULT;
        activeWindow = null;
      });

      // --- FOCUS (skip locked windows) ---
      windows.forEach((win) => {
        win.addEventListener("mousedown", () => {
          if (win.dataset.notMoveable === "true") return;
          setActiveWindow(win);
        });
      });

      // --- CLOSE BUTTONS ---
      document.querySelectorAll<HTMLElement>(".close").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const target = e.target as HTMLElement;
          const windowEl = target.closest(".window");

          if (!windowEl) return;

          if (target.dataset.redirect === "true") {
            window.location.href = "https://nikostuff.com";
            return;
          }

          windowEl.remove();
        });
      });
    </script>

    <div
      class="cf-turnstile"
      data-sitekey="0x4AAAAAACBNatxTQCTb20u7"
      data-size="normal"
      data-theme="dark"
      data-callback="onSuccess"
    >
    </div>
    <script>
      declare const turnstile: {
        reset: () => void;
      };

      const notify_sound: HTMLAudioElement | null = document.getElementById(
        "notify",
      ) as HTMLAudioElement;
      const chatLog: HTMLUListElement | null =
        document.querySelector(".chat-log");
      const sendBtn: HTMLButtonElement | null = document.getElementById(
        "sendBtn",
      ) as HTMLButtonElement;
      const nickInput: HTMLInputElement | null = document.getElementById(
        "nickname",
      ) as HTMLInputElement;
      const msgInput: HTMLInputElement | null = document.getElementById(
        "message",
      ) as HTMLInputElement;

      // Map to store colors per username
      const userColors: Record<string, string> = {};

      // Helper to generate random color
      function getReadableRandomColor(): string {
        const h = Math.floor(Math.random() * 360);
        const s = 70;
        const l = 40;

        return `hsl(${h}, ${s}%, ${l}%)`;
      }

      // Helper to log to the UI window
      function log_message(from: string, text: string) {
        if (!chatLog) return;

        const li: HTMLLIElement = document.createElement("li");

        // Assign color if not assigned yet
        if (!userColors[from]) {
          userColors[from] = getReadableRandomColor();
        }

        li.innerHTML = `<strong style="color: ${userColors[from]}">${from} - </strong> ${text}`;
        chatLog.appendChild(li);

        // Auto-scroll to bottom
        chatLog.scrollTop = chatLog.scrollHeight;
        if (notify_sound) {
          notify_sound.volume = 0.05;
          notify_sound
            .play()
            .catch((e) => console.error("Audio play failed:", e));
        }
      }

      // 2. Clean Unicode Function
      function cleanString(str: string): string {
        return str.replace(/[^\x00-\x7F]/g, "").trim();
      }

      // --- Reconnectable WebSocket ---
      let ws: WebSocket | null = null;
      const WS_URL = "wss://ws_wall.nikostuff.com";
      const RECONNECT_DELAY = 5000; // 5 seconds

      function connectSocket() {
        ws = new WebSocket(WS_URL);

        ws.onopen = () => {
          log_message("System", "Polaczono z websocket-em.");
        };

        ws.onmessage = (event: MessageEvent<string>) => {
          const data = JSON.parse(event.data);

          switch (data.event) {
            case "chat.message":
              log_message(data.data.from, data.data.message);
              break;

            case "chat.history":
              data.data.messages.forEach(
                (msg: { from: string; message: string }) => {
                  log_message(msg.from, msg.message);
                },
              );
              break;

            case "welcome":
              log_message("System", "Polaczono z serwerem.");
              break;

            case "error":
              log_message("System", data.data.message);
              break;
          }
        };

        ws.onclose = () => {
          log_message(
            "System",
            "Polaczenie przerwane. Próba ponownego polaczenia za 5s...",
          );
          setTimeout(connectSocket, RECONNECT_DELAY);
        };

        ws.onerror = (err) => {
          console.error("WebSocket error:", err);
          ws?.close(); // trigger reconnect
        };
      }

      // Start the socket initially
      connectSocket();

      // 4. Send Message Logic
      sendBtn?.addEventListener("click", () => {
        if (!nickInput || !msgInput || !ws) return;

        const nick: string = cleanString(nickInput.value);
        const msg: string = cleanString(msgInput.value);

        const turnstileRes: string | undefined = (
          document.querySelector(
            '[name="cf-turnstile-response"]',
          ) as HTMLInputElement | null
        )?.value;

        if (!nick || !msg) {
          log_message("System", "Pola nie moga byc puste!");
          return;
        }

        if (!turnstileRes) {
          log_message("System", "Dokoncz weryfikacje!");
          return;
        }

        // Set username first
        ws.send(
          JSON.stringify({
            event: "chat.setUsername",
            data: { username: nick },
          }),
        );

        // Send the message
        ws.send(
          JSON.stringify({
            event: "chat.message",
            data: {
              message: msg,
              "cf-turnstile": turnstileRes,
            },
          }),
        );

        msgInput.value = "";

        if (typeof turnstile !== "undefined") turnstile.reset();
      });
    </script>
  </body>
</html>
