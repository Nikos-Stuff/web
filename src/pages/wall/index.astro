---
import "@styles/wall_styling.css";
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Amazing Wall</title>
    <link rel="stylesheet" href="https://unpkg.com/98.css" />
    <link rel="preconnect" href="https://challenges.cloudflare.com" />

    <script
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer></script>
  </head>
  <body>
    <div
      id="first_interaction_grabber"
      style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
            background: rgba(0, 0, 0, 0.5); z-index: 800; 
            display: flex; align-items: center; justify-content: center;"
    >
      <div
        class="window"
        data-not-moveable="true"
        style="position: relative; width: 300px;"
      >
        <div class="title-bar">
          <div class="title-bar-text">Hello World!</div>
        </div>
        <div class="window-body" style="text-align: center;">
          <p>Welcome to my silly place!</p>
          <p>Still work in progress - but whatever!</p>
          <section class="field-row" style="justify-content: center;">
            <button id="start_button" style="width: 80px;">OK</button>
          </section>
        </div>
      </div>
    </div>

    <div class="window win_anim">
      <div class="title-bar">
        <div class="title-bar-text">Guest book</div>
        <div class="title-bar-controls">
          <button aria-label="Close" class="close" data-redirect="true"
          ></button>
        </div>
      </div>
      <div class="window-body">
        <div class="marquee-container">
          <marquee scrollamount="3">Leave a random message! ( Global )</marquee>
        </div>
        <fieldset>
          <legend>Write a Message:</legend>
          <div class="field-row-stacked">
            <label for="nickname">Your nickname:</label>
            <input id="nickname" type="text" autocomplete="off" />
          </div>
          <div class="field-row-stacked">
            <label for="message">Message:</label>
            <textarea id="message" rows="3"></textarea>
          </div>
          <button id="sendBtn" style="margin-top: 10px;">Send</button>
        </fieldset>
        <ul class="tree-view chat-log">
          <li><strong>System: </strong>Waiting...</li>
        </ul>
      </div>
      <audio id="intro_sound" src="/win98.ogv"></audio>
      <audio id="notify" src="/you_got_mail.ogg"></audio>
    </div>

    <div class="window win_anim" style="height: 160px">
      <div class="title-bar">
        <div class="title-bar-text">Active Users</div>
      </div>
      <div
        class="sunken-panel"
        style="height: 100%; width: 100%; margin-top: 2px;"
      >
        <table style="width: 100%;" id="ActiveUsersTable">
          <thead>
            <tr>
              <th>Name</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody></tbody>
        </table>
      </div>
      <div class="status-bar">
        <p class="status-bar-field">
          Active Users: <strong id="activeConnections">0</strong>
        </p>
      </div>
    </div>

    <div
      class="window win_anim"
      id="radioWindow"
      style="top: 120px; left: 400px;"
    >
      <div class="title-bar">
        <div class="title-bar-text">Lofi Radio</div>
        <div class="title-bar-controls">
          <button aria-label="Close" class="close"></button>
        </div>
      </div>
      <div class="window-body" style="padding: 0; background: black;">
        <iframe
          id="ytPlayer"
          height="200"
          src="https://www.youtube.com/embed/jfKfPfyJRdk?enablejsapi=1&controls=0&modestbranding=1&rel=0"
          allow="autoplay"
          style="pointer-events: none;"
        >
        </iframe>
      </div>
    </div>

    <div
      class="window win_anim"
      id="globalPaint"
      style="width: auto; display: inline-block;"
    >
      <div class="title-bar">
        <div class="title-bar-text">Paint</div>
        <div class="title-bar-controls">
          <button aria-label="Close" class="close"></button>
        </div>
      </div>

      <div
        class="window-body"
        style="margin: 0; display: flex; flex-direction: column;"
      >
        <div
          id="canvasStage"
          style="position: relative; line-height: 0; overflow-x: auto; width: 100%; margin-top: 2px;"
        >
          <img
            id="canvasLoader"
            src="/bsdos.png"
            alt="Canvas Loader"
            style="display: none; position: absolute; top: 0; left: 0; width: 504px; height: 304px; pointer-events: none; z-index: 2; image-rendering: pixelated;"
          />
          <img
            id="staticCanvas"
            src=""
            alt="Canvas Background"
            style="position: absolute; top: 0; left: 0; width: 504px; height: 304px; pointer-events: none; background-color: #ffffff; z-index: -1; image-rendering: pixelated;"
          />
          <canvas
            id="paintCanvas"
            width="500"
            height="300"
            style="background: transparent; cursor: crosshair; display: block; width: 504px; height: 304px;"
          ></canvas>
        </div>
      </div>

      <div
        style="display: flex; flex-direction: row; align-items: center; padding: 5px; border-top: 1px solid #808080; gap: 15px;"
      >
        <div class="field-row" style="margin: 0;">
          <label style="font-size: 10px;">Color:</label>
          <input
            id="colorInput"
            type="color"
            value="#000000"
            style="width: 30px; height: 30px;"
          />
        </div>

        <div class="field-row" style="margin: 0; flex-grow: 1;">
          <label for="brushSize" style="font-size: 10px;">Size:</label>
          <input
            id="brushSize"
            type="range"
            min="1"
            max="20"
            value="5"
            style="width: 100px;"
          />
        </div>

        <div
          class="sizeBrushPreview"
          style="width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; border: 2px inset #ffffff; background: white;"
        >
          <div
            id="sizePreview"
            style="background: black; border-radius: 50%; width: 5px; height: 5px;"
          >
          </div>
        </div>

        <div class="status-bar" style="flex-grow: 1; height: 20px;">
          <p
            class="status-bar-field"
            id="coords"
            style="width: 80px; margin: 0;text-align: center;"
          >
            0, 0
          </p>
          <p
            class="status-bar-field"
            style="width: 60px; margin: 0; text-align: center;"
          >
            <span id="brushDisplay">5</span>px
          </p>
        </div>
      </div>
    </div>

    <div class="window win_anim" style="width: 120px; display: inline-block;">
      <div class="title-bar">
        <div class="title-bar-text">Links</div>
        <div class="title-bar-controls">
          <button aria-label="Close" class="close"></button>
        </div>
      </div>

      <div
        class="window-body"
        style="margin: 0; display: flex; flex-direction: column; align-items: center; padding: 10px; gap: 8px;"
      >
        <a href="https://bartkk.xyz" target="_blank">
          <img
            src="https://bartkk.xyz/img/buttons/button-zack.gif"
            alt="Zack The Raccoon"
            style="display: block;"
          />
        </a>
      </div>
      <div class="status-bar">
        <p class="status-bar-field">Other silly stuff</p>
      </div>
    </div>

    <div class="taskbar">
      <div class="taskbar-left-section"></div>

      <div class="status-bar tray">
        <img
          src="https://win98icons.alexmeub.com/icons/png/network_normal_two_pcs-3.png"
          width="16"
          alt="net"
        />
        <div id="wsStatsTaskbar" class="tray-stats">
          <span id="stat-rate">0/s</span>
          <span class="stat-divider">|</span>
          <span id="stat-in">0.00KB</span>
          <span class="stat-divider">|</span>
          <span id="stat-out">0.00KB</span>
        </div>
        <div id="tray-clock">12:00 PM</div>
      </div>
    </div>

    <div
      class="cf-turnstile"
      data-sitekey="0x4AAAAAACBNatxTQCTb20u7"
      data-size="normal"
      data-theme="dark"
      data-callback="onSuccess"
    >
    </div>
  </body>
</html>

<script src="src/win98/websocket.ts" />
<script src="src/win98/windows_manager.ts" />
