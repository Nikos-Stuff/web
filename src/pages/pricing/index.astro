---
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@consts";
import MeteorShower from "@components/MeteorShower.astro";
import TwinklingStars from "@components/TwinklingStars.astro";
import Carousel from "@components/pricing_carousel.astro";
import TimeLine from "@components/pricing_timeline.astro";
import Accordion from "@components/Accordion.astro";
import TitleHeader from "@components/TitleHeader.astro";
import OpenPopup from "@components/StripePopup.astro";
import FancyDiv from "@components/FancyDiv.astro";
import BackgroundFX from "@components/page_effects/BackgroundFX.astro";
---

<PageLayout title="Pricing" description={SITE.DESCRIPTION}>
  <!-- Dark Theme: Stars -->
  <div class="absolute inset-0 block">
    <div id="stars1" class="fixed inset-0"></div>
    <div id="stars2" class="fixed inset-0"></div>
    <div id="stars3" class="fixed inset-0"></div>
  </div>

  <!-- Dark Theme: Twinkling Stars / Meteors -->
  <div id="galaxy" class="fixed inset-0">
    <div class="block">
      <TwinklingStars />
      <MeteorShower />
    </div>
  </div>

  <!-- <script is:inline defer src="/js/bg.js"></script> -->
  <BackgroundFX />

  <!-- HERO -->
  <section
    class="snap-center grid w-full h-[80vh] place-items-center relative text-center overflow-hidden transition-all"
  >
    <TitleHeader text="Cennik" sub="Usługi, Oferty itp." buttons={false} />
  </section>

  <!-- Popup manager -->
  <OpenPopup />

  <!-- Pricing - Web Design-->
  <div class="relative">
    <!-- <div class="mx-auto max-w-screen-sm p-5 space-y-24 pb-16"> -->
    <!-- About Section -->
    <FancyDiv margin_bottom="50" isAnimated={true}>
      <section class="animate">
        <p>
          Podstawowe oferty / usługi. <br /> Pamiętaj że podane ceny są jedynie „szacowane/średnie”
          i mogą ulec zmianie po negocjacjach / po zrealizowaniu zamówienia (w zależności
          od rodzaju zamówienia).
        </p>
      </section>
    </FancyDiv>

    <FancyDiv margin_bottom="50" isAnimated={true}>
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between">
            <p id="web" class="font-semibold text-white">Strony WWW</p>
          </div>
          <div class="space-y-4 transition-all duration-300 ease-in-out">
            <!-- Starter Plan -->
            <div class="animate">
              <div
                class="group h-auto p-4 gap-3 flex flex-col items-start border rounded-lg hover:scale-105 hover:bg-white/10 border-white/20 transition-all duration-300 ease-in-out relative"
              >
                <div class="w-full z-10 relative">
                  <div class="absolute top-0 right-0 opacity-10">
                    <i class="ph ph-browsers text-6xl text-gray-300"></i>
                  </div>

                  <div
                    class="text-sm capitalize px-3 py-1 rounded-full border border-white/25 w-max"
                  >
                    Web
                  </div>
                  <div class="font-semibold mt-3 mb-3 text-white text-xl">
                    Starter
                  </div>
                  <div class="text-sm text-gray-400">
                    Prosta, funkcjonalna strona oparta na WordPressie. Idealna
                    dla małych firm potrzebujących stabilnej obecności w sieci.
                    <div class="flex flex-col mt-4 gap-2 text-white">
                      <div class="flex items-center gap-2">
                        <i class="ph ph-code-block text-xl"></i>
                        <span><strong>WordPress CMS</strong> ready</span>
                      </div>
                      <div class="flex items-center gap-2">
                        <i class="ph ph-device-mobile text-xl"></i>
                        <span><strong>Mobile Friendly</strong> design</span>
                      </div>
                      <div class="flex items-center gap-2">
                        <i class="ph ph-shield-check text-xl"></i>
                        <span
                          ><strong>Aktualizacje</strong> i bezpieczeństwo</span
                        >
                      </div>
                    </div>
                  </div>
                  <div class="mt-6 font-semibold text-white">
                    <span class="text-2xl">350 PLN / mies.</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Hybrid Plan -->
            <div class="animate">
              <div
                class="gray-shine group h-auto p-4 gap-3 flex flex-col items-start border rounded-lg hover:scale-105 hover:bg-blue-400/10 border-blue-400/20 transition-all duration-300 ease-in-out relative"
              >
                <div class="w-full z-10 relative">
                  <div class="absolute top-0 right-0 opacity-10">
                    <i class="ph ph-database text-6xl text-gray-300"></i>
                  </div>

                  <div
                    class="text-sm capitalize px-3 py-1 rounded-full border border-blue-400/50 text-blue-200 w-max"
                  >
                    Hybrid
                  </div>
                  <div class="font-semibold mt-3 mb-3 text-white text-xl">
                    Headless + Astro SSR
                  </div>
                  <div class="text-sm text-gray-400">
                    Najwyższa wydajność. WordPress pełni rolę bezpiecznego
                    zaplecza (CMS), a Astro.js generuje błyskawiczną stronę.
                    <div class="flex flex-col mt-4 gap-2 text-white">
                      <div class="flex items-center gap-2">
                        <i class="ph ph-rocket text-xl text-blue-400"></i>
                        <span><strong>Astro.js</strong> SSR performance</span>
                      </div>
                      <div class="flex items-center gap-2">
                        <i class="ph ph-gear text-xl text-blue-400"></i>
                        <span><strong>Headless</strong> API architecture</span>
                      </div>
                      <div class="flex items-center gap-2">
                        <i class="ph ph-chart-line text-xl text-blue-400"></i>
                        <span><strong>Zaawansowana</strong> optymalizacja</span>
                      </div>
                    </div>
                  </div>
                  <div class="mt-6 font-semibold text-white">
                    <span class="text-2xl">1200 PLN / mies.</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Static Plan -->
            <div class="animate">
              <div
                class="shine group h-auto p-4 gap-3 flex flex-col items-start border rounded-lg hover:scale-105 hover:bg-yellow-400/10 border-yellow-400/20 transition-all duration-300 ease-in-out relative"
              >
                <div class="w-full z-10 relative">
                  <div class="absolute top-0 right-0 opacity-10">
                    <i class="ph ph-file-html text-6xl text-gray-300"></i>
                  </div>

                  <div
                    class="text-sm capitalize px-3 py-1 rounded-full border border-yellow-400/50 text-yellow-200 w-max"
                  >
                    Static
                  </div>
                  <div class="font-semibold mt-3 mb-3 text-white text-xl">
                    Strona Statyczna
                  </div>
                  <div class="text-sm text-gray-400">
                    Rozwiązanie dla wymagających szybkości. Wykorzystanie
                    GitHuba i Astro do serwowania statycznych treści.
                    <div class="flex flex-col mt-4 gap-2 text-white">
                      <div class="flex items-center gap-2">
                        <i class="ph ph-markdown-logo text-xl text-yellow-400"
                        ></i>
                        <span><strong>System</strong> Markdown</span>
                      </div>
                      <div class="flex items-center gap-2">
                        <i class="ph ph-lightning text-xl text-yellow-400"></i>
                        <span><strong>Automatyzacja</strong> CI/CD</span>
                      </div>
                      <div class="flex items-center gap-2">
                        <i class="ph ph-github-logo text-xl text-yellow-400"
                        ></i>
                        <span><strong>Wersjonowanie</strong> kodu</span>
                      </div>
                    </div>
                  </div>
                  <div class="mt-6 font-semibold text-white">
                    <span class="text-2xl">900 PLN / mies.</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="flex justify-center my-4">
              <i class="ph ph-arrow-down text-2xl animate-bounce"></i>
            </div>

            <!-- All stuff thingy -->
            <div class="animate">
              <div
                class="relative overflow-hidden rounded-lg border border-indigo-500/30 p-6 hover:bg-indigo-900/10 hover:scale-105 transition-all duration-300 ease-in-out"
              >
                <div class="relative z-10">
                  <div class="flex items-center gap-3 mb-4">
                    <h3 class="font-semibold text-white text-lg">
                      Kompleksowy pakiet w cenie projektu
                    </h3>
                  </div>

                  <p class="text-sm text-gray-300 mb-6 leading-relaxed">
                    Wybierając współpracę ze mną, nie otrzymujesz tylko kodu.
                    Każdy projekt to w pełni przygotowane, bezpieczne i
                    zoptymalizowane środowisko pracy:
                  </p>

                  <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-xs">
                    <div class="flex items-center gap-2 text-indigo-200">
                      <i class="ph ph-rocket-launch text-base"></i>
                      <span><strong>Stabilny hosting</strong> WWW</span>
                    </div>
                    <div class="flex items-center gap-2 text-indigo-200">
                      <i class="ph ph-package text-base"></i>
                      <span>Projekt gotowy pod <strong>deploy</strong></span>
                    </div>
                    <div class="flex items-center gap-2 text-indigo-200">
                      <i class="ph ph-shield-check text-base"></i>
                      <span>Zabezpieczenia <strong>CrowdSec</strong></span>
                    </div>
                    <div class="flex items-center gap-2 text-indigo-200">
                      <i class="ph ph-wrench text-base"></i>
                      <span
                        >Ciągłe <strong>poprawki i optymalizacje</strong></span
                      >
                    </div>
                    <div
                      class="flex items-center gap-2 text-indigo-200 col-span-full"
                    >
                      <i class="ph ph-envelope-simple text-base"></i>
                      <span
                        >Pełna konfiguracja <strong>domeny i poczty</strong
                        ></span
                      >
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <a
        href="/contactus"
        class="group p-4 gap-3 flex items-center border rounded-lg hover:scale-105 hover:bg-white/10 border-white/20 transition-all duration-300 ease-in-out"
      >
        <span
          class="w-full z-10 relative group-hover:text-white text-center transition-color duration-300"
        >
          
        </span>
      </a>
    </FancyDiv>

    <FancyDiv margin_bottom="50" isAnimated={true}>
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between">
            <p id="hosting_related" class="font-semibold text-white">
              Konfiguracja i Zarządzanie Hostingiem
            </p>
          </div>
          <div class="space-y-4 transition-all duration-300 ease-in-out">
            <!-- Starter Plan -->
            <div
              class="gray-shine group h-auto p-4 gap-3 flex flex-col items-start border rounded-lg hover:bg-white/10 border-white/20 transition-all duration-300 ease-in-out relative"
            >
              <div class="w-full z-10 relative group-hover:text-white blend">
                <div class="flex flex-wrap items-center gap-2">
                  <div
                    class="text-sm capitalize px-3 py-1 rounded-full border border-white/25"
                  >
                    Server Management
                  </div>
                </div>
                <div class="font-semibold mt-3 mb-3 text-white">
                  Profesjonalna Opieka Serwera
                </div>
                <div class="text-sm">
                  Hosting, konfiguracja i bezpieczeństwo - bez kompromisów. <br
                  />
                  Perfekcyjnie dopasowane do Twoich potrzeb, z pełną dostępnością,
                  niezawodnością i bezpieczeństwem.

                  <div class="flex flex-col items-start mt-3 gap-1">
                    <div class="flex items-center gap-2">
                      <i class="ph ph-shield-check text-xl"></i>
                      <span>
                        <strong>Ultra Bezpieczny</strong>
                      </span>
                    </div>

                    <div class="flex items-center gap-2">
                      <i class="ph ph-seal-check text-xl"></i>
                      <span>
                        Zaufany <strong>Dostawca</strong>
                      </span>
                    </div>

                    <div class="flex items-center gap-2">
                      <i class="ph ph-arrows-clockwise text-xl"></i>
                      <span>
                        <strong>Zawsze Aktualny & Dostępny</strong>
                      </span>
                    </div>
                  </div>
                </div>

                <div class="flex items-stretch mt-4 mb-4">
                  <!-- Vertical line -->
                  <div class="mr-3 rounded-full bg-white/20 w-1"></div>

                  <!-- Content -->
                  <div class="font-semibold text-white">
                    <span class="text-2xl">Do Uzgodnienia</span>
                    <p class="text-sm text-gray-400 mt-2">Breakdown:</p>
                    <p class="text-xs text-gray-400">
                      ? PLN - Cena wybranego pakietu
                    </p>
                    <p class="text-xs text-gray-400">
                      200 PLN - Ciągły monitoring i konserwacja
                    </p>
                    <p class="text-xs text-gray-400">
                      100-300 PLN - Konfiguracja serwera i bezpieczeństwo
                    </p>
                    <p class="text-xs text-gray-400">
                      50-100 PLN - Raporty miesięczne
                    </p>
                  </div>
                </div>

                <ul class="flex flex-wrap mt-2 gap-1">
                  <li
                    class="text-xs uppercase py-0.5 px-1 rounded bg-white/20 text-white/75"
                  >
                    NOWOŚĆ
                  </li>
                </ul>
              </div>
            </div>

            <!-- Checkout Offerts -->
            <a
              href="https://skillhost.pl/dostepne-serwery"
              target="_blank"
              class="group p-4 gap-3 flex items-center border rounded-lg hover:scale-105 hover:bg-white/10 border-white/20 transition-all duration-300 ease-in-out"
            >
              <span
                class="w-full z-10 relative group-hover:text-white text-center transition-color duration-300"
              >
                Zobacz dostępne serwery <small>(SkillHost.pl)</small>
              </span>
            </a>
          </div>
        </div>
      </section>
    </FancyDiv>

    <FancyDiv margin_bottom="50" isAnimated={true}>
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between">
            <p id="local_services" class="font-semibold text-white">
              Lokalne Usługi
            </p>
          </div>
          <div class="space-y-4 transition-all duration-300 ease-in-out">
            <!-- LOCAL 3D PRINT Plan -->
            <div class="animate">
              <div
                class="gray-shine group h-auto p-4 gap-3 flex flex-col items-start border rounded-lg hover:bg-white/10 border-white/20 transition-all duration-300 ease-in-out relative"
              >
                <div class="w-full z-10 relative group-hover:text-white blend">
                  <div class="flex flex-wrap items-center gap-2">
                    <div
                      class="text-sm capitalize px-3 py-1 rounded-full border border-white/25"
                    >
                      3D Printing
                    </div>
                  </div>
                  <div class="font-semibold mt-3 mb-3 text-white">
                    Wydruki 3D
                  </div>
                  <div class="text-sm">
                    Potrzebujesz wydrukować coś w 3D lub stworzyć model? <br />
                    Różnolite materiały (PLA, PETG, TPU, PVA), precyzyjne wydruki
                    i szybka realizacja z możliwością projektowania modeli na zamówienie.

                    <div class="flex flex-col items-start mt-3 gap-1">
                      <div class="flex items-center gap-2">
                        <i class="ph ph-arrows-out text-xl"></i>
                        <span>
                          Max <strong>330 x 320 x 325 mm³</strong>
                        </span>
                      </div>

                      <div class="flex items-center gap-2">
                        <i class="ph ph-paint-bucket text-xl"></i>
                        <span>
                          Wielomateriałowe <strong>Wydruki</strong>
                          <small> (AMS)</small>
                        </span>
                      </div>

                      <div class="flex items-center gap-2">
                        <i class="ph ph-truck text-xl"></i>
                        <span>
                          Szybka Dostawa <small>(InPost)</small> i <strong
                            >Realizacja</strong
                          >
                        </span>
                      </div>
                    </div>
                  </div>

                  <div class="flex items-stretch mt-4 mb-4">
                    <!-- Vertical line -->
                    <div class="mr-3 rounded-full bg-white/20 w-1"></div>

                    <!-- Content -->
                    <div class="font-semibold text-white">
                      <span class="text-2xl">Do Uzgodnienia</span>
                      <p class="text-sm text-gray-400 mt-2">Breakdown:</p>
                      <p class="text-xs text-gray-400">
                        ? PLN - Typ i zakres wydruku
                      </p>
                      <p class="text-xs text-gray-400">
                        0.50-1.50 PLN / g - Standardowa stawka za gram
                      </p>
                      <p class="text-xs text-gray-400">
                        20-50 PLN - Koszt wysyłki (w zależności od wagi i
                        rozmiaru)
                      </p>
                      <p class="text-xs text-gray-400">
                        50-100 PLN - Koszt projektowania modelu na zamówienie
                      </p>
                    </div>
                  </div>

                  <ul class="flex flex-wrap mt-2 gap-1">
                    <li
                      class="text-xs uppercase py-0.5 px-1 rounded bg-white/20 text-white/75"
                    >
                      NOWOŚĆ
                    </li>
                    <li
                      class="text-xs uppercase py-0.5 px-1 rounded bg-yellow-300/20 text-yellow-200/75"
                    >
                      LOKALNE - TYLKO W LIMANOWEJ
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </FancyDiv>

    <FancyDiv margin_bottom="50" isAnimated={true} theme="lite">
      <!-- Using solid bg theme for this one -->
      <Carousel />
      <script is:inline defer src="/js/carousel.js"></script>
    </FancyDiv>
  </div>
  <!-- </div> -->

  <TimeLine />

  <!-- Important notes -->
  <section class="relative bg-neutral-950">
    <div class="animate mx-auto max-w-screen-sm p-5 space-y-24 pb-16 mt-8">
      <article>
        <p
          class="text-xl md:text-2xl lg:text-3xl font-bold uppercase text-white mb-2"
        >
          FAQ
        </p>

        <Accordion
          title="Co jest wliczone w cenę?"
          details="Podana cena obejmuje wszystkie prace projektowe i rozwojowe opisane w opisie pakietu. Hosting i rejestracja domeny są wliczone w cenę."
        />
        <Accordion
          title="Czy są jakieś ukryte koszty?"
          details="Brak ukrytych opłat. Wszystkie koszty są komunikowane z góry, a wszelkie dodatkowe prace zostaną wycenione do zatwierdzenia."
        />
        <Accordion
          title="Czy pakiety można personalizować?"
          details="Tak, pakiety mogą być dostosowane do konkretnych potrzeb. Skontaktuj się ze mną, aby uzyskać spersonalizowaną wycenę."
        />
        <Accordion
          title="Które metody płatności są wspierane?"
          details="Płatności można dokonać za pośrednictwem przelewu lub PayPal."
        />
        <Accordion
          title="Czy oferujesz wsparcie po zakończeniu projektu?"
          details="Tak, oferuję wsparcie i konserwację po zakończeniu projektu. Możemy ustalić szczegóły w zależności od Twoich potrzeb."
        />
        <Accordion
          title="Jak długo trwa realizacja projektu?"
          details="Czas realizacji zależy od zakresu projektu. Standardowy czas realizacji to 1-2 tygodnie, ale może się różnić w zależności od specyfikacji."
        />
        <Accordion
          title="Czy mogę zmienić pakiet po rozpoczęciu projektu?"
          details="Tak, możesz zmienić pakiet w trakcie realizacji projektu. Skontaktuj się ze mną, aby omówić szczegóły."
        />
        <Accordion
          title="Czy mogę anulować projekt po jego rozpoczęciu?"
          details="Tak, możesz anulować projekt w dowolnym momencie. W takim przypadku naliczona zostanie opłata za wykonane prace do momentu anulowania."
        />
        <Accordion
          title="Czy oferujesz gwarancję satysfakcji?"
          details="Tak, oferuję gwarancję satysfakcji. Jeśli nie jesteś zadowolony z końcowego produktu, skontaktuj się ze mną, a postaramy się znaleźć rozwiązanie."
        />
      </article>
    </div>
  </section>

  <!-- Ending -->
  <div
    class="animate p-5 text-center min-h-150 flex items-center justify-center"
  >
    <div class="relative flex flex-col items-center justify-center w-full">
      <p
        id="touch-tite"
        class="text-xl md:text-2xl lg:text-5xl font-bold uppercase text-white"
      >
        Bądźmy w kontakcie.
      </p>

      <!-- Buttons -->
      <div
        class="flex flex-col sm:flex-row items-center justify-center gap-3 mt-4 w-full max-w-xs sm:max-w-none"
      >
        <!-- Fiverr -->
        <a
          href="https://www.fiverr.com/s/xXEvD2l"
          target="_blank"
          class="backdrop-blur-sm group w-40 p-4 gap-3 flex items-center border rounded-lg hover:scale-105 hover:bg-white/10 border-white/20 transition-all duration-300 ease-in-out"
        >
          <span
            class="w-full z-10 relative group-hover:text-white text-center transition-color duration-300"
          >
            Fiverr
          </span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="stroke-current group-hover:stroke-white z-10"
          >
            <line
              x1="5"
              y1="12"
              x2="19"
              y2="12"
              class="scale-x-0 group-hover:scale-x-100 translate-x-4 group-hover:translate-x-1 transition-all duration-300 ease-in-out"
            ></line>
            <polyline
              points="12 5 19 12 12 19"
              class="translate-x-0 group-hover:translate-x-1 transition-all duration-300 ease-in-out"
            ></polyline>
          </svg>
        </a>

        <!-- Facebook -->
        <a
          href="https://www.facebook.com/maciek.fraczek.965"
          target="_blank"
          class="backdrop-blur-sm group w-40 p-4 gap-3 flex items-center border rounded-lg hover:scale-105 hover:bg-white/10 border-white/20 transition-all duration-300 ease-in-out"
        >
          <span
            class="w-full z-10 relative group-hover:text-white text-center transition-color duration-300"
          >
            Facebook
          </span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="stroke-current group-hover:stroke-white z-10"
          >
            <line
              x1="5"
              y1="12"
              x2="19"
              y2="12"
              class="scale-x-0 group-hover:scale-x-100 translate-x-4 group-hover:translate-x-1 transition-all duration-300 ease-in-out"
            ></line>
            <polyline
              points="12 5 19 12 12 19"
              class="translate-x-0 group-hover:translate-x-1 transition-all duration-300 ease-in-out"
            ></polyline>
          </svg>
        </a>
      </div>
    </div>
  </div>
</PageLayout>
